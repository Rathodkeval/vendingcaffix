{
  "name": "caffix-monorepo",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "supportedArchitectures": {
    "os": ["win32", "linux"],
    "cpu": ["x64"]
  },
  "workspaces": [
    "caffix-app",
    "caffix-backend"
  ],
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.3",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.1",
    "@tailwindcss/oxide-linux-x64-musl": "4.3.1"
  },
  "scripts": {
    "build": "npm run build --workspace=caffix-backend && npm run build --workspace=caffix-app"
  }
}
